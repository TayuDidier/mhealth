# Copy this file to .env.local and fill in your Supabase credentials.
# In production (e.g. Vercel), set these as project Environment Variables instead.
# Leaving them unset makes the app run in demo mode with local seed data.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Twilio credentials are used server-side only in the Supabase Edge Function.
# Do NOT put Twilio secrets in this frontend env file — configure them as
# Edge Function secrets in your Supabase project settings.
